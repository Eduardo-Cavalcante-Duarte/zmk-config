#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    // Define a default keymap here.
    // See https://zmk.dev/docs/development/hardware-integration/new-shield#default-keymap.

    combos {
        compatible = "zmk,combos";

        a1 {
            bindings = <&a1>;
            key-positions = <24 16>;
            layers = <0>;
        };

        a2 {
            bindings = <&a2>;
            key-positions = <24 17>;
            layers = <0>;
        };

        a3 {
            bindings = <&a3>;
            key-positions = <24 18>;
            layers = <0>;
        };

        a4 {
            bindings = <&a4>;
            key-positions = <24 19>;
            layers = <0>;
        };

