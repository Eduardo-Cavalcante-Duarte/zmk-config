#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    // Define a default keymap here.
    // See https://zmk.dev/docs/development/hardware-integration/new-shield#default-keymap.

    combos {
        compatible = "zmk,combos";

        a1 {
            bindings = <&a1>;
            key-positions = <24 16>;
            layers = <0>;
        };

        a2 {
            bindings = <&a2>;
            key-positions = <24 17>;
            layers = <0>;
        };

        a3 {
            bindings = <&a3>;
            key-positions = <24 18>;
            layers = <0>;
        };

        a4 {
            bindings = <&a4>;
            key-positions = <24 19>;
            layers = <0>;
        };

        o1 {
            bindings = <&o1>;
            key-positions = <23 16>;
            layers = <0>;
        };

        o2 {
            bindings = <&o2>;
            key-positions = <23 17>;
            layers = <0>;
        };

        o3 {
            bindings = <&o3>;
            key-positions = <23 18>;
            layers = <0>;
        };

        o4 {
            bindings = <&o4>;
            key-positions = <23 19>;
            layers = <0>;
        };

        game {
            bindings = <&to 1>;
            key-positions = <31 43>;
            layers = <0>;
        };

        base {
            bindings = <&to 0>;
            key-positions = <31 43>;
            layers = <1>;
        };

        cedilha {
            bindings = <&kp SEMI>;
            key-positions = <27 30>;
            layers = <0>;
        };
    };

    macros {
        a1: a1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SINGLE_QUOTE &kp A>;
            label = "A1";
        };

        a2: a2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACKET &kp A>;
            label = "A2";
        };

        a3: a3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(SINGLE_QUOTE) &kp A>;
            label = "A3";
        };

        a4: a4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(LEFT_BRACKET) &kp A>;
            label = "A4";
        };

        e1: e1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SINGLE_QUOTE &kp E>;
            label = "E1";
        };

        e2: e2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACKET &kp E>;
            label = "E2";
        };

        e3: e3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(SINGLE_QUOTE) &kp E>;
            label = "E3";
        };

