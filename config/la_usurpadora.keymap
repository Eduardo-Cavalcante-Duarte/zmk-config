            bindings = <&to 1>;
            key-positions = <31 43>;
            layers = <0>;
        };

        base {
            bindings = <&to 0>;
            key-positions = <31 43>;
            layers = <1>;
        };
    };

    macros {
        a1: a1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SINGLE_QUOTE &kp A>;
            label = "A1";
        };

        a2: a2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACKET &kp A>;
            label = "A2";
        };

        a3: a3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(SINGLE_QUOTE) &kp A>;
            label = "A3";
        };

        a4: a4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(LEFT_BRACKET) &kp A>;
            label = "A4";
        };

