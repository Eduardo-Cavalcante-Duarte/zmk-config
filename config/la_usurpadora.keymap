    keymap {
        compatible = "zmk,keymap";

        BASE {
            bindings = <
         &kp NUMBER_1          &kp N2              &kp N3          &kp N4              &kp NUMBER_5                    &kp N6     &kp N7                &kp N8          &kp N9              &kp N0
         &kp G                 &kp L               &kp T           &kp M               &kp PERIOD                      &kp COMMA  &kp U                 &kp C           &kp P               &kp V
&kp ESC  &mt LEFT_SHIFT N      &mt LEFT_CONTROL R  &mt LEFT_ALT O  &mt LEFT_GUI A      &kp Y                           &kp W      &mt LEFT_GUI E        &mt LEFT_ALT S  &mt LEFT_CONTROL I  &mt LEFT_SHIFT D      &kp ESC
&kp ESC  &mt LC(LEFT_SHIFT) K  &kp J               &kp F           &mt LS(LEFT_GUI) Q  &kp SLASH                       &kp INT1   &mt LG(LEFT_SHIFT) H  &kp B           &kp Z               &mt LC(LEFT_SHIFT) X  &kp ESC
                               &kp LC(C)           &kp LC(V)       &lt 3 ESC           &lt 2 SPACE   &kp TAB  &kp RET  &kp BSPC   &kp DEL               &kp ESC         &kp ESC
                                                                                       &kp ESC       &kp ESC  &kp ESC  &kp ESC
            >;

            sensor-bindings =
                <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>,
                <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>;
        };

        GAMING {
            bindings = <
         &kp N1     &kp N2   &kp N3   &kp N4   &kp N5                       &kp N6    &kp N7   &kp N8   &kp N9     &kp N0
         &kp TAB    &kp Q    &kp W    &kp R    &kp T                        &kp Y     &kp U    &kp I    &kp O      &kp P
&kp ESC  &kp LSHFT  &kp A    &kp S    &kp D    &kp F                        &kp G     &kp H    &kp J    &kp K      &kp K    &kp K
&kp ESC  &kp LCTRL  &kp Z    &kp X    &kp C    &kp V                        &kp B     &kp N    &kp M    &kp COMMA  &kp DOT  &kp ESC
                    &kp ESC  &kp ESC  &kp ESC  &kp SPACE  &kp TAB  &kp RET  &kp BSPC  &kp DEL  &kp ESC  &kp ESC
                                               &kp ESC    &kp ESC  &kp ESC  &kp ESC
            >;

            sensor-bindings =
                <&inc_dec_kp PG_UP PG_DN>,
                <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        MOVE {
            bindings = <
         &kp F1  &kp F2       &kp F3      &kp F4  &kp F5                     &kp F6           &kp F7    &kp F8       &kp F9      &kp F10
         &trans  &trans       &trans      &trans  &trans                     &kp PRINTSCREEN  &trans    &trans       &trans      &trans
&kp F11  &trans  &trans       &trans      &trans  &trans                     &kp CAPSLOCK     &kp LEFT  &kp DOWN     &kp UP      &kp RIGHT  &trans
&kp F12  &trans  &trans       &trans      &trans  &trans                     &kp INSERT       &kp HOME  &kp PG_DN    &kp PG_UP   &kp END    &trans
                 &bootloader  &sys_reset  &trans  &trans  &trans  &kp ENTER  &kp BACKSPACE    &kp DEL   &bootloader  &sys_reset
                                                  &trans  &trans  &trans     &trans
            >;

            sensor-bindings =
                <&inc_dec_kp PG_UP PG_DN>,
                <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        SYM {
            bindings = <
               &msc SCRL_UP       &msc SCRL_DOWN  &kp N3  &kp N4               &kp N5            &kp N6  &kp N7  &kp N8  &kp N9  &kp N0
               &kp LS(RBKT)       &kp             &kp     &kp LS(NON_US_HASH)  &kp               &kp     &kp     &kp     &kp     &kp
&kp LS(GRAVE)  &kp RIGHT_BRACKET  &kp             &kp     &kp NON_US_HASH      &kp               &kp     &kp     &kp     &kp     &kp     &kp
&kp GRAVE      &kp LS(N9)         &kp             &kp     &kp LS(N0)           &kp               &kp     &kp     &kp     &kp     &kp     &kp
                                  &kp             &kp     &kp                  &kp     &kp  &kp  &kp     &kp     &kp     &kp
                                                                               &kp     &kp  &kp  &kp
            >;

            sensor-bindings =
                <&inc_dec_kp PG_UP PG_DN>,
                <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        layer_4 {
            bindings = <
        &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
        &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
                                        &trans  &trans  &trans  &trans
